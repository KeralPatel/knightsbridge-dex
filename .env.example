# ============================================
# KNIGHTSBRIDGE DEX — ENVIRONMENT VARIABLES
# ============================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- 0x Protocol ----
# Get your key at https://0x.org/
ZERO_EX_API_KEY=your-0x-api-key

# ---- RPC Endpoints ----
# Alchemy recommended for reliability
ETH_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-key
BASE_MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-key
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key

# ---- Worker Authentication ----
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
WORKER_HMAC_SECRET=your-64-char-hex-hmac-secret

# ---- JWT ----
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=your-jwt-secret-min-32-chars

# ---- Smart Contract Addresses ----
# Populated after deployment via scripts/deploy.ts
NEXT_PUBLIC_TOKEN_FACTORY_ETH=0x
NEXT_PUBLIC_TOKEN_FACTORY_BASE=0x
NEXT_PUBLIC_LIQUIDITY_LOCKER_ETH=0x
NEXT_PUBLIC_LIQUIDITY_LOCKER_BASE=0x

# ---- Hardhat (contracts only) ----
DEPLOYER_PRIVATE_KEY=your-deployer-private-key
ETHERSCAN_API_KEY=your-etherscan-key
BASESCAN_API_KEY=your-basescan-key

# ---- Optional: Upstash Redis (caching) ----
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ---- App Config ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_CHAIN_ID=1

# ---- Worker (Render.com) ----
# Base URL of the deployed Next.js app — used by worker to POST signals
API_BASE_URL=https://your-domain.vercel.app
